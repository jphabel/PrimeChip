@{
}

<!-- TOP STAT CARDS -->
<div class="row g-3 mb-4 top-stat">
    <!--Total Stock Products-->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body d-flex align-items-center gap-4 flex-nowrap">
                <i class="bi bi-box fs-1 text-primary flex-shrink-0"></i>
                <div>
                    <h6 class="m-0 text-muted">Total Stock Products</h6>
                    <p class="m-0 fw-bold">9,999</p>
                </div>
            </div>
        </div>
    </div>
    <!--Low Stock Products-->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body d-flex align-items-center gap-4">
                <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
                <div>
                    <h6 class="m-0 text-muted">Low Stock Products</h6>
                    <p class="m-0 fw-bold">50</p>
                </div>
            </div>
        </div>
    </div>
    <!--Out of Stock Items-->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body d-flex align-items-center gap-4">
                <i class="bi bi-exclamation-circle fs-1 text-danger"></i>
                <div>
                    <h6 class="m-0 text-muted">Out of Stock Items</h6>
                    <p class="m-0 fw-bold">10</p>
                </div>
            </div>
        </div>
    </div>
    <!--Total Inventory Value-->
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body d-flex align-items-center gap-4">
                <i class="bi bi-cash-coin fs-1 text-success"></i>
                <div>
                    <h6 class="m-0 text-muted">Total Inventory Value</h6>
                    <p class="m-0 fw-bold">99999</p>
                </div>
            </div>
        </div>
    </div>
</div>

</div>