@{
    ViewData["Title"] = "Inventory";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js"></script>
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                    <h1 class="fw-bold">Inventory</h1>
                    <p class="text-muted">Track product,stock levels, reorder status.</p>
                    </div>
                    <div>
                        <button type="button" class="btn btn-primary rounded-5" data-bs-toggle="modal" data-bs-target="#addProductModal">+ Add Product</button>
                    </div>
                </div>
                
                <!--TOP STATS-->
                <partial name="_TopStats" />

                <!--TABLE-->
                <div class="card p-2">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <input class="form-control rounded-5" placeholder="Search"/>
                        </div>
                        <div class="d-flex">
                            <select id="filterCategory" class="form-select" style="width: 200px;" onchange="filterTable()">
                                <option value="">All Categories</option>
                                <option>Storage</option>
                                <option>Memory</option>
                                <option>Processor</option>
                            </select>
                        
                            <select id="filterStatus" class="form-select ms-1 me-1" style="max-width: 160px;" onchange="filterTable()">
                                <option value="">All Statuses</option>
                                <option>In Stock</option>
                                <option>Low Stock</option>
                                <option>Out of Stock</option>
                            </select>

                            <button class="btn btn-outline-secondary">Clear</button>
                        </div>
                    </div>
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>STOCK QTY</th>
                                <th>REORDER LEVEL</th>
                                <th>UNIT PRICE</th>
                                <th>STATUS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>
                        <tbody class="border-1">
                            <tr>
                                <td class="text-muted">HP SSD 512GB</td>
                                <td>123456789</td>
                                <td>Storage</td>
                                <td>300</td>
                                <td>20</td>
                                <td>$9,999.00</td>
                                <td><span class="badge bg-success">In stock</span></td>
                                <td class="text-muted">
                                    <button class="btn btn-success">Edit</button>
                                    <button class="btn btn-danger">Delete</button>
                                </td>
                            </tr>
