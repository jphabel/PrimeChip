@model List<PrimeChip.Models.Inventory>;

@{
    ViewData["Title"] = "Inventory";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

@section Scripts {
    <script src="~/js/inventory.js"></script>
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Inventory</h1>
                        <p class="text-muted">Track product,stock levels, reorder status.</p>
                    </div>
                    <div>
                        <button type="button" class="btn btn-primary rounded-5" data-bs-toggle="modal" data-bs-target="#addProductModal">+ Add Product</button>
                    </div>
                </div>
                
                <!--TABLE-->
                <!--TABLE-->
                <div class="card p-2">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <input class="form-control rounded-5" id="searchInput" placeholder="Search"/>
                        </div>
                        <div class="d-flex">
                            <select id="filterCategory" class="form-select">
                                <option value="">All Categories</option>
                                <option value="storage">Storage</option>
                                <option value="memory">Memory</option>
                                <option value="processor">Processor</option>
                                <option value="videocard">Video Card</option>
                                <option value="motherboard">Motherboard</option>
                                <option value="peripherals">Peripherals</option>
                            </select>
        
                            <select id="filterStatus" class="form-select ms-1 me-1" style="max-width: 160px;">
                                <option value="">All Statuses</option>
                                <option value="out of stock">Out of Stock</option>
                                <option value="low stock">Low Stock</option>
                                <option value="reorder needed">Reorder Needed</option>
                                <option value="in stock">In Stock</option>
                            </select>

                            <button class="btn btn-outline-secondary" id="clear-btn" onclick="clearFilters()">Clear</button>
                        </div>
                    </div>
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>Product</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>INITIAL STOCK</th>
                                <th>STOCK QTY</th>
                                <th>REORDER LEVEL</th>
                                <th>UNIT PRICE</th>
                                <th>STATUS</th>
                                <th>DATE</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>
                        <tbody class="border-1">
                            @foreach (var Item in Model)
                            {
                                <tr>
                                    <td class="text-muted">@Item.Name</td>
                                    <td>@Item.SKU</td>
                                    <td>@Item.Category</td> 
                                    <td>@Item.Stock</td>
                                    <td>@Item.Stock</td>
                                    <td>@Item.ReorderLevel</td>
                                    <td>@Item.UnitPrice</td>
                                    <td>
                                        @if (Item.Stock == 0)
                                        {
                                            <span class="badge bg-danger">Out of Stock</span>
                                        }
                                        else if (Item.Stock < 10)
                                        {
                                            <span class="badge bg-warning text-dark">Low Stock</span>
                                        }
                                        else if (Item.Stock <= Item.ReorderLevel)
                                        {
                                            <span class="badge bg-warning">Reorder Needed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">In Stock</span>
                                        }
                                    </td>
                                    <td>@Item.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    <td class="text-muted">
                                        <a href="/Inventory/Edit/@Item.Id" class="btn btn-success">Edit</a>
                                        <button class="btn btn-danger" onclick="confirmDelete(@Item.Id)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
            </div>

        </main>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModal" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="addProductModal">Enter Product Details</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Inventory" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label for="Name" class="form-label">Product</label>
                        <input name="Name" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="SKU" class="form-label">SKU</label>
                        <input name="SKU" type="number" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <select name="Category" class="form-select" required>
                            <option disabled selected>Category</option>
                            <option value="Storage">Storage</option>
                            <option value="Processor">Processor</option>
                            <option value="VideoCard">Video Card</option>
                            <option value="Motherboard">Motherboard</option>
                            <option value="Peripherals">Peripherals</option>
                            <option value="Memory">Memory</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="Stock" class="form-label">Stock qty</label>
                        <input name="Stock" type="number" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="ReorderLevel" class="form-label">Reorder Level</label>
                        <input name="ReorderLevel" type="number" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="UnitPrice" class="form-label">Unit Price</label>
                        <input name="UnitPrice" type="number" class="form-control" required>
                    </div>
                    <div class=" d-flex justify-content-end">
                        <button type="submit" class="btn btn-success">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this product? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" value="" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>