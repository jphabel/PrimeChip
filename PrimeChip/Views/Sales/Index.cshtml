@model List<PrimeChip.Models.Sale>

@{
    ViewData["Title"] = "Sales";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>
        <main class="p-3">
            <div class="container-fluid">
                <div class="mb-4">
                    <h1 class="fw-bold">Sales</h1>
                    <p class="text-muted">Monitor stock movements.</p>
                </div>

                <div class="card p-2">
                    <table class="table table-bordered table-sm table-hover align-middle border-1 mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>TYPE</th>
                                <th>QUANTITY</th>
                                <th>UNIT PRICE</th>
                                <th>TOTAL</th>
                                <th>DATE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in Model)
                            {
                                <tr>
                                    <td class="text-muted">@sale.ProductName</td>
                                    <td>@sale.SKU</td>
                                    <td>
                                        @if (sale.Type == "Stock In")
                                        {
                                            <span class="badge bg-success">Stock In</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Stock Out</span>
                                        }
                                    </td>
                                    <td>@sale.Quantity</td>
                                    <td>₱@sale.UnitPrice.ToString("N2")</td>
                                    <td>₱@sale.TotalAmount.ToString("N2")</td>
                                    <td>@sale.CreatedAt.ToString("MMM dd, yyyy hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>