@{
    ViewData["Title"] = "Sales";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Sales</h1>
                        <p class="text-muted">Monitor stock movements.</p>
                    </div>
                </div>
                
                <!--TABLE-->
                <div class="card p-2">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <input class="form-control rounded-5" id="searchInput" placeholder="Search" />
                        </div>
                        <div class="d-flex">
                            <select id="filterCategory" class="form-select" style="width: 200px;" onchange="filterTable()">
                                <option value="">All Categories</option>
                                <option value="Storage">Storage</option>
                                <option value="Memory">Memory</option>
                                <option value="Processor">Processor</option>
                                <option value="VideoCard">Video Card</option>
                                <option value="Motherboard">Motherboard</option>
                                <option value="Peripherals">Peripherals</option>
                            </select>
                        
                            <select id="filterStatus" class="form-select ms-1 me-1" style="max-width: 160px;" onchange="filterTable()">
                                <option value="">All Statuses</option>
                                <option>In Stock</option>
                                <option>Low Stock</option>
                                <option>Out of Stock</option>
                            </select>

                            <button class="btn btn-outline-secondary" id="clear-btn" onclick="clearFilters()">Clear</button>
                        </div>
                    </div>
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>PRODUCT</th>
                                <th>STOCK IN</th>
                                <th>STOCK OUT</th>
                                <th>UNIT PRICE</th>
                                <th>TOTAL</th>
                                <th>STATUS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>
                        <tbody class="border-1">
                            <tr>
                                <td>1TB SSD SEAGATE</td>
                                <td>50</td>
                                <td>10</td>
                                <td>5000</td>
                                <td>50000</td>
                                <td>Out of Stock</td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Out</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
            </div>

        </main>
    </div>
</div>
