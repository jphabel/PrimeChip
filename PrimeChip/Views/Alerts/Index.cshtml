@model List<PrimeChip.Models.Inventory>;

@{
    ViewData["Title"] = "Alerts";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

@section Scripts {
    <script src="~/js/alerts.js"></script>
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Alerts</h1>
                        <p class="text-muted">View important inventory stock alerts.</p>
                    </div>
                    <div>
                        <a asp-controller="Vendors" asp-action="index" class="btn btn-primary rounded-5">
                            <span class="ms-2">View Vendors</span>
                        </a>
                    </div>
                </div>

                <!-- TABLE -->
                <div class="card p-2">
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>STOCK QTY</th>
                                <th>STATUS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>

                        <tbody class="border-1">
                            @foreach (var Item in Model)
                            {
                                <tr>
                                    <td class="text-muted">@Item.Name</td>
                                    <td>@Item.SKU</td>
                                    <td>@Item.Category</td>
                                    <td>@Item.Stock</td>
                                    <td><span>
                                        @if (Item.Stock == 0)
                                        {
                                            <span class="badge bg-danger">Out of Stock</span>
                                        }
                                        else if (Item.Stock < 10)
                                        {
                                            <span class="badge bg-warning text-dark">Low Stock</span>
                                        }
                                        else if (Item.Stock <= Item.ReorderLevel)
                                        {
                                            <span class="badge bg-warning">Reorder Needed</span>
                                        }                                                   
                                    </span></td>
                                    <td>
                                        <button class="btn btn-success btn-sm"
                                            onclick="openPurchaseModal(@Item.Id, '@Item.Name', @Item.ReorderLevel, @Item.Stock)">
                                            Purchase
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>

        </main>
    </div>
</div>

<div class="modal fade" id="purchaseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Purchase Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="purchaseForm" method="post" asp-controller="Alerts" asp-action="Purchase">
                @Html.AntiForgeryToken()
                <input type="hidden" name="inventoryId" id="purchaseInventoryId" />
                <div class="modal-body">
                    <p>Product: <strong id="purchaseProductName"></strong></p>
                    <p>Current Stock: <strong id="purchaseCurrentStock"></strong></p>
                    <p>Reorder Level: <strong id="purchaseReorderLevel"></strong></p>
                    <div class="mb-3">
                        <label class="form-label">Quantity to Purchase</label>
                        <input type="number" name="quantity" class="form-control" min="1" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Purchase</button>
                </div>
            </form>
        </div>
    </div>
</div>