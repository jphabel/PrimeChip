@{
    ViewData["Title"] = "Alerts";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

@section Scripts {
    <script src="~/js/alerts.js"></script>
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Alerts</h1>
                        <p class="text-muted">View important inventory stock alerts.</p>
                    </div>
                </div>

                <!-- TABLE -->
                <div class="card p-2">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <input class="form-control rounded-5" id="searchInput" placeholder="Search" />
                        </div>

                        <div class="d-flex">
                            <select id="filterCategory" class="form-select" style="width: 200px;" onchange="filterTable()">
                                <option value="">All Categories</option>
                                <option>Storage</option>
                                <option>Memory</option>
                                <option>Processor</option>
                                <option>Video Card</option>
                                <option>Motherboard</option>
                                <option>Peripherals</option>
                            </select>

                            <select id="filterStatus" class="form-select ms-1 me-1" style="max-width: 170px;" onchange="filterTable()">
                                <option value="">All Statuses</option>
                                <option>Low Stock</option>
                                <option>Out of Stock</option>
                                <option>Reorder Needed</option>
                            </select>

                            <button class="btn btn-outline-secondary" id="clear-btn" onclick="clearFilters()">Clear</button>
                        </div>
                    </div>

                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>STOCK QTY</th>
                                <th>REORDER LEVEL</th>
                                <th>UNIT PRICE</th>
                                <th>STATUS</th>
                            </tr>
                        </thead>

                        <tbody class="border-1">
                            <tr>
                                <td class="text-muted">HP SSD 512GB</td>
                                <td>123456789</td>
                                <td>Storage</td>
                                <td>5</td>
                                <td>20</td>
                                <td>$9,999.00</td>
                                <td><span class="badge bg-warning text-dark">Low Stock</span></td>
                            </tr>

                            <tr>
                                <td class="text-muted">Ryzen 5 5600G</td>
                                <td>987654321</td>
                                <td>Processor</td>
                                <td>0</td>
                                <td>10</td>
                                <td>$7,500.00</td>
                                <td><span class="badge bg-danger">Out of Stock</span></td>
                            </tr>

                            <tr>
                                <td class="text-muted">Kingston RAM 8GB</td>
                                <td>456789123</td>
                                <td>Memory</td>
                                <td>8</td>
                                <td>15</td>
                                <td>$1,800.00</td>
                                <td><span class="badge bg-warning text-dark">Low Stock</span></td>
                            </tr>

                            <tr>
                                <td class="text-muted">ASUS Motherboard B450</td>
                                <td>789123456</td>
                                <td>Motherboard</td>
                                <td>3</td>
                                <td>10</td>
                                <td>$4,200.00</td>
                                <td><span class="badge bg-danger">Reorder Needed</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>

        </main>
    </div>
</div>