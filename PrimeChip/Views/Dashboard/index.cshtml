@{
    ViewData["Title"] = "dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}


@section Scripts {
    <script src="~/js/dashboard.js"></script>
}

<div class="d-flex">
<partial name="_SideNav" />
    
    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />

        <main class="p-3">

            <div class="container-fluid"> 
                <!--Main-header -->
                <div>
                    <h1 class="fw-bold">Welcome back, Admin!</h1>
                    <p class="text-muted">
                        Here's what's happening with your projects today.
                    </p>
                </div>

                <!-- Top stat cards-->
                <div class="row g-3 mb-4">
                    <!-- card 1 total product -->
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-4">
                                 <i class="bi bi-box fs-1 text-primary"></i>
                                 <div class="m-0 p-0">
                                     <h6 class="m-0">Total Stock Products</h6>
                                     <p>9,999</p>
                                </div>
                            </div>
                        </div>
                    </div>           
                    <!-- card 2 low stocks -->
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-4">
                                <i class="bi bi-exclamation-triangle fs-1 text-warning"></i>
                                <div class="m-0 p-0">
                                    <h6 class="m-0">Low Stock Products</h6>
                                    <p>50</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- card 3 out of stock items -->
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-4">
                                <i class="bi bi-exclamation-circle fs-1 text-danger"></i>
                                <div class="m-0 p-0">
                                    <h6 class="m-0">Out of Stock Items</h6>
                                    <p>10</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- card 1 total inventory value -->
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-4">
                                <i class="bi bi-cash-coin fs-1 text-success"></i>
                                <div class="m-0 p-0">
                                    <h6 class="m-0">Total Inventory Value</h6>
                                    <p>$99,999.99</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!--Bottom stat cards-->

            <!--Upper-->
            <div class="row mb-1 g-3 p-3 justify-content-evenly">
                <div class="col-md-5">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex align-items-center gap-4">
                            <i class="bi bi-box fs-1 text-primary"></i>
                            <div class="m-0 p-0">
                                <h6 class="m-0">Total Stock Products</h6>
                                <p>9,999</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex align-items-center gap-4">
                            <i class="bi bi-box fs-1 text-primary"></i>
                            <div class="m-0 p-0">
                                <h6 class="m-0">Total Stock Products</h6>
                                <p>9,999</p>
                            </div>
                        </div>
                    </div>
                </div>
               
            </div>
            <!--Lower-->
            <div class="row g-3 p-3 justify-content-evenly">
                <div class="col-md-5">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex align-items-center gap-4">
                            <i class="bi bi-box fs-1 text-primary"></i>
                            <div class="m-0 p-0">
                                <h6 class="m-0">Total Stock Products</h6>
                                <p>9,999</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body d-flex align-items-center gap-4">
                            <i class="bi bi-box fs-1 text-primary"></i>
                            <div class="m-0 p-0">
                                <h6 class="m-0">Total Stock Products</h6>
                                <p>9,999</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            
        </main>
    </div>
</div>
