@model PrimeChip.Models.User
@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <div class="mb-4">
                    <h1 class="fw-bold">Profile</h1>
                    <p class="text-muted">Manage account information and profile settings.</p>
                </div>

                <div class="card p-4">

                    <div class="text-center mb-4">
                        @if (Model?.ProfileImage == null)
                        {
                            <img src="~/images/avatar.jpg"
                            class="rounded-circle border mb-3"
                            width="120"
                            height="120"
                            style="object-fit: cover;" />
                        }else
                        {
                            <img src="@Model.ProfileImage"
                                 class="rounded-circle border mb-3"
                                 width="120"
                                 height="120"
                                 style="object-fit: cover;" />
                        }

                    </div>
                    <form asp-controller="Profile"
                              asp-action="Update"
                              method="post"
                              enctype="multipart/form-data">

                        <div>
                            <label class="form-label">Upload Your Profile</label>
                            <input type="file" name="profilePhoto"class="form-control" />
                        </div>


                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input asp-for="FullName" type="text" class="form-control" value="@Model.FullName">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" value="@Model.Email">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input asp-for="Username" type="text" class="form-control" value="@Model.Username">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <input asp-for="Password" type="password" class="form-control" value="@Model.Password">
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-success rounded-5">
                                Save Changes
                            </button>
                        </div>

                    </form>

                </div>

            </div>

        </main>
    </div>
</div>