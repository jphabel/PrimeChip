@model List<PrimeChip.Models.Vendor>;

@{
    ViewData["Title"] = "Vendors";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

@section Scripts {
    <script src="~/js/Vendors.js"></script>
}


<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Vendors</h1>
                        <p class="text-muted">Vendor list</p>
                    </div>
                    <div>
                        <a class="btn btn-outline-secondary rounded-5" href="Alerts/Index">Back</a>
                        <button class="btn btn-primary rounded-5" data-bs-toggle="modal" data-bs-target="#addVendorModal">+ Add Vendors</button>
                    </div>
                </div>

                <!--TABLE-->
                <div class="card p-2">
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <input class="form-control rounded-5" id="searchInput" placeholder="Search" />
                        </div>
                        <div class="d-flex">
                            <button class="btn btn-outline-secondary" id="clear-btn" onclick="clearFilters()">Clear</button>
                        </div>
                    </div>
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle border-1 mb-0">
                        <thead class="table-light table-responsive border-1">
                            <tr>
                                <th>VENDOR</th>
                                <th>CONTACT NUMBER</th>
                                <th>ADDRESS</th>
                                <th>ACTION</th>
                            </tr>
                        </thead>
                        <tbody class="border-1">
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.vendorName</td>
                                    <td>@item.contactNumber</td>
                                    <td>@item.address</td>
                                    <td class="text-muted">
                                        <button type="submit"><a href="Vendors/Edit" class="btn btn-success">Edit</a></button>
                                        <button class="btn btn-danger">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

     
            </div>

        </main>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="addVendorModal" tabindex="-1" aria-labelledby="addVendorModal" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="addVendorModal">Enter Vendor Details</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Vendors" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label for="" class="form-label">Vendor Name</label>
                        <input name="vendorName"type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="" class="form-label">Contact Number</label>
                        <input name="contactNumber" type="text" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="" class="form-label">Address</label>
                        <input name="address" type="text" class="form-control" required>
                    </div>
                    <div class=" d-flex justify-content-end">
                        <button type="submit" class="btn btn-success">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>