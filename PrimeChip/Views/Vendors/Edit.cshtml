@{
    ViewData["Title"] = "Edit Vendor";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- MAIN CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- PAGE HEADER -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Edit Vendor</h1>
                        <p class="text-muted">Update vendor information and contact details.</p>
                    </div>

                    <div>
                        <a href="/Vendors" class="btn btn-outline-secondary rounded-5">Back</a>
                    </div>
                </div>

                <!-- FORM -->
                <div class="card p-4">

                    <form>

                        <div class="mb-3">
                            <label class="form-label">Vendor Name</label>
                            <input type="text" class="form-control" value="TechSource Solutions">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Contact Number</label>
                            <input type="text" class="form-control" value="123456789">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Address</label>
                            <input type="text" class="form-control" value="123 Tech Street, Silicon Valley, CA">
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/Vendors" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">Save Changes</button>
                        </div>

                    </form>

                </div>

            </div>

        </main>
    </div>
</div>