@{
    ViewData["Title"] = "Sales Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">
            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Sales Report</h1>
                        <p class="text-muted">View stock-in value and stock-out revenue reports.</p>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="/Reports" class="btn btn-outline-secondary rounded-5">Back</a>
                        <a href="#" class="btn btn-success rounded-5">
                            <i class="bi bi-printer-fill me-1"></i> Print Report
                        </a>
                    </div>
                </div>

                <!-- Stock In Table -->
                <div class="card border-0 shadow-sm p-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="fw-bold mb-0">Stock In</h5>
                            <small class="text-muted">Products added to inventory.</small>
                        </div>
                    </div>

                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT NAME</th>
                                <th>QTY</th>
                                <th>TOTAL VALUE</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">Kingston RAM 8GB</td>
                                <td>20</td>
                                <td>₱36,000.00</td>
                            </tr>
                            <tr>
                                <td class="text-muted">ASUS Motherboard B450</td>
                                <td>10</td>
                                <td>₱42,000.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Stock Out Table -->
                <div class="card border-0 shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="fw-bold mb-0">Stock Out</h5>
                            <small class="text-muted">Products sold or released from inventory.</small>
                        </div>
                    </div>

                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT NAME</th>
                                <th>QTY</th>
                                <th>TOTAL REVENUE</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">Kingston RAM 8GB</td>
                                <td>12</td>
                                <td>₱21,600.00</td>
                            </tr>
                            <tr>
                                <td class="text-muted">ASUS Motherboard B450</td>
                                <td>7</td>
                                <td>₱29,400.00</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </main>
    </div>
</div>