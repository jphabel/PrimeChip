@model List<PrimeChip.Models.Sale>

@{
    ViewData["Title"] = "Sales Report";
    var stockIn = Model.Where(s => s.Type == "Stock In").ToList();
    var stockOut = Model.Where(s => s.Type == "Stock Out").ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>
        <main class="p-3">
            <div class="container-fluid">
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Sales Report</h1>
                        <p class="text-muted">View stock-in and stock-out movements.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/Reports" class="btn btn-outline-secondary rounded-5">Back</a>
                        <a href="#" class="btn btn-success rounded-5" onclick="window.print()">
                            <i class="bi bi-printer-fill me-1"></i> Print Report
                        </a>
                    </div>
                </div>

                <!-- Stock In -->
                <div class="card border-0 shadow-sm p-3 mb-4">
                    <h5 class="fw-bold mb-1">Stock In</h5>
                    <small class="text-muted d-block mb-3">Products purchased and added to inventory.</small>
                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>QTY</th>
                                <th>UNIT PRICE</th>
                                <th>TOTAL VALUE</th>
                                <th>DATE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in stockIn)
                            {
                                <tr>
                                    <td class="text-muted">@sale.ProductName</td>
                                    <td>@sale.SKU</td>
                                    <td>@sale.Quantity</td>
                                    <td>₱@sale.UnitPrice.ToString("N2")</td>
                                    <td>₱@sale.TotalAmount.ToString("N2")</td>
                                    <td>@sale.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Stock Out -->
                <div class="card border-0 shadow-sm p-3">
                    <h5 class="fw-bold mb-1">Stock Out</h5>
                    <small class="text-muted d-block mb-3">Products sold or released from inventory.</small>
                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>QTY</th>
                                <th>UNIT PRICE</th>
                                <th>TOTAL REVENUE</th>
                                <th>DATE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sale in stockOut)
                            {
                                <tr>
                                    <td class="text-muted">@sale.ProductName</td>
                                    <td>@sale.SKU</td>
                                    <td>@sale.Quantity</td>
                                    <td>₱@sale.UnitPrice.ToString("N2")</td>
                                    <td>₱@sale.TotalAmount.ToString("N2")</td>
                                    <td>@sale.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </main>
    </div>
</div>