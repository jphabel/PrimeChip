@model List<PrimeChip.Models.CategorySummaryViewModel>

@{
    ViewData["Title"] = "Total Inventory Value Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>
        <main class="p-3">
            <div class="container-fluid">
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Total Inventory Value Report</h1>
                        <p class="text-muted">Total value grouped by category.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/Reports" class="btn btn-outline-secondary rounded-5">Back</a>
                        <a href="#" class="btn btn-success rounded-5" onclick="window.print()">
                            <i class="bi bi-printer-fill me-1"></i> Print Report
                        </a>
                    </div>
                </div>

                <div class="card p-3">
                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>CATEGORY</th>
                                <th>TOTAL STOCK QTY</th>
                                <th>TOTAL VALUE</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model)
                            {
                                <tr>
                                    <td>@row.Category</td>
                                    <td>@row.TotalStock</td>
                                    <td>₱@row.TotalValue.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="2">Grand Total</td>
                                <td>@ViewBag.GrandTotal.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>