@{
    ViewData["Title"] = "Out of Stock Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">
            <div class="container-fluid">

                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Out of Stock Report</h1>
                        <p class="text-muted">Products that currently have zero stock available.</p>
                    </div>

                    <div class="d-flex gap-2">
                        <a href="/Reports" class="btn btn-outline-secondary rounded-5">Back</a>
                        <a href="#" class="btn btn-success rounded-5">
                            <i class="bi bi-printer-fill me-1"></i> Print Report
                        </a>
                    </div>
                </div>

                <div class="card p-3">
                    <table class="table table-bordered table-sm table-hover table-responsive align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>STOCK QTY</th>
                                <th>REORDER LEVEL</th>
                                <th>UNIT PRICE</th>
                                <th>STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-muted">Ryzen 5 5600G</td>
                                <td>987654321</td>
                                <td>Processor</td>
                                <td>0</td>
                                <td>10</td>
                                <td>$7,500.00</td>
                                <td><span class="badge bg-danger">Out of Stock</span></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Logitech Mouse</td>
                                <td>654321987</td>
                                <td>Peripherals</td>
                                <td>0</td>
                                <td>12</td>
                                <td>$850.00</td>
                                <td><span class="badge bg-danger">Out of Stock</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </main>
    </div>
</div>