@model List<PrimeChip.Models.Inventory>

@{
    ViewData["Title"] = "Inventory Summary Report";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
}

<div class="layout-wrapper">
    <partial name="_SideNav" />
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>
        <main class="p-3">
            <div class="container-fluid">
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Inventory Summary Report</h1>
                        <p class="text-muted">Summary of all inventory products.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/Reports" class="btn btn-outline-secondary rounded-5">Back</a>
                        <a href="#" class="btn btn-success rounded-5" onclick="window.print()">
                            <i class="bi bi-printer-fill me-1"></i> Print Report
                        </a>
                    </div>
                </div>

                <div class="card p-3">
                    <table class="table table-bordered table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PRODUCT</th>
                                <th>SKU</th>
                                <th>CATEGORY</th>
                                <th>STOCK QTY</th>
                                <th>REORDER LEVEL</th>
                                <th>UNIT PRICE</th>
                                <th>STATUS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-muted">@item.Name</td>
                                    <td>@item.SKU</td>
                                    <td>@item.Category</td>
                                    <td>@item.Stock</td>
                                    <td>@item.ReorderLevel</td>
                                    <td>₱@item.UnitPrice.ToString("N2")</td>
                                    <td>
                                        @if (item.Stock == 0)
                                        {
                                            <span class="badge bg-danger">Out of Stock</span>
                                        }
                                        else if (item.Stock < 10)
                                        {
                                            <span class="badge bg-warning text-dark">Low Stock</span>
                                        }
                                        else if (item.Stock <= item.ReorderLevel)
                                        {
                                            <span class="badge bg-warning">Reorder Needed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">In Stock</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</div>