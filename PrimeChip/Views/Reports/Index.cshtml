@{
    ViewData["Title"] = "Reports";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
    <link rel="stylesheet" href="~/css/reports.css" />
}

@section Scripts {
    <script src="~/js/reports.js"></script>
}

<div class="layout-wrapper">
    <partial name="_SideNav" />

    <!-- DASHBOARD CONTENT -->
    <div class="main flex-column bg-light">
        <partial name="_TopNav" />
        <div id="sidebar-backdrop"></div>

        <main class="p-3">

            <div class="container-fluid">

                <!-- Page Header -->
                <div class="mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="fw-bold">Reports</h1>
                        <p class="text-muted">View important inventory reports.</p>
                    </div>
                </div>

                <!-- REPORT CARDS -->
                <div class="row g-4">

                    <div class="col-md-6 col-lg-3">
                        <a href="/Reports/InventorySummary" class="text-decoration-none">
                            <div class="card report-card shadow-sm border-0 h-100">
                                <div class="card-body p-4">
                                    <div class="report-icon bg-primary-subtle text-primary mb-3">
                                        <i class="bi bi-file-earmark-bar-graph"></i>
                                    </div>
                                    <h5 class="fw-bold text-dark">Inventory Summary</h5>
                                    <p class="text-muted mb-0">View all products and stock information.</p>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <a href="/Reports/SalesReport" class="text-decoration-none">
                            <div class="card report-card shadow-sm border-0 h-100">
                                <div class="card-body p-4">
                                    <div class="report-icon bg-warning-subtle text-warning mb-3">
                                        <i class="bi bi-currency-dollar"></i>
                                    </div>
                                    <h5 class="fw-bold text-dark">Sales Report</h5>
                                    <p class="text-muted mb-0">Check products that need restocking soon.</p>
                                </div>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <a href="/Reports/TotalInventoryValue" class="text-decoration-none">
                            <div class="card report-card shadow-sm border-0 h-100">
                                <div class="card-body p-4">
                                    <div class="report-icon bg-success-subtle text-success mb-3">
                                        <i class="bi bi-piggy-bank"></i>
                                    </div>
                                    <h5 class="fw-bold text-dark">Inventory Value</h5>
                                    <p class="text-muted mb-0">See the total value of your inventory.</p>
                                </div>
                            </div>
                        </a>
                    </div>

                </div>

            </div>

        </main>
    </div>
</div>